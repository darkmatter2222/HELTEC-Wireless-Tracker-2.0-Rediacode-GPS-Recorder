// =============================================================================
// HTIT-Tracker Wi-Fi / cloud-upload secrets - EXAMPLE.
//
// Copy this file to `secrets.h` and fill in your values.
// `secrets.h` is gitignored; this `.example` is committed.
// =============================================================================
#pragma once

namespace secrets {

// ---- Wi-Fi network the tracker should auto-join when in range ----
// Leave WIFI_SSID empty ("") to disable Wi-Fi entirely.
constexpr const char* WIFI_SSID     = "";
constexpr const char* WIFI_PASSWORD = "";

// ---- Vega Tracker Ingest API endpoint ----
// Full URL of the /ingest/csv endpoint. Use http:// (not https://) for
// local LAN servers; ESP32 supports HTTPS but root certs cost flash.
//   e.g.  http://192.168.86.48:8030/ingest/csv
constexpr const char* INGEST_URL = "";

// ---- Upload behavior ----
// How often to attempt a connect+drain cycle when there are sessions to upload.
constexpr uint32_t UPLOAD_INTERVAL_MS    = 60000;     // 60s
// How long to wait for the AP association before giving up.
constexpr uint32_t WIFI_CONNECT_TIMEOUT_MS = 12000;   // 12s

} // namespace secrets
