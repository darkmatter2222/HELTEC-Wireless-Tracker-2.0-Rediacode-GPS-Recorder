// =============================================================================
// HTIT-Tracker Wi-Fi / cloud-upload secrets - EXAMPLE.
//
// Copy this file to `secrets.h` and fill in your values.
// `secrets.h` is gitignored; this `.example` is committed.
//
// Dual-network support (v0.9.0):
//   The tracker tries the HOME network first each upload cycle.
//   If the home AP is not in range it falls back to the REMOTE network
//   (e.g. a phone hotspot) and uploads to the internet-facing endpoint.
//   Both profiles are optional independently -- fill in only the ones you need.
// =============================================================================
#pragma once

namespace secrets {

// ---- PRIMARY (home) Wi-Fi network ----
// The tracker tries this SSID first on every upload cycle.
// Set WIFI_SSID empty ("") to disable the home profile.
constexpr const char* WIFI_SSID     = "";
constexpr const char* WIFI_PASSWORD = "";

// Ingest API endpoint reachable from the home LAN (direct, no auth needed).
//   e.g.  http://192.168.86.48:8030/ingest/csv
constexpr const char* INGEST_URL = "";

// ---- SECONDARY (mobile hotspot) Wi-Fi network ----
// Optional fallback. When WIFI_SSID2 is empty the hotspot profile is disabled.
// Both WIFI_SSID2 AND INGEST_URL2 must be non-empty for the fallback to work.
constexpr const char* WIFI_SSID2     = "";
constexpr const char* WIFI_PASSWORD2 = "";

// Internet-facing ingest endpoint (e.g. DuckDNS / nginx reverse proxy).
// HTTPS is supported; TLS certificate verification is skipped to avoid
// embedding root CA chains in flash.  The data (GPS + radiation) is
// low-sensitivity so MITM risk on a residential hotspot is acceptable.
//   e.g.  https://susmannet.duckdns.org/api/ingest/csv
constexpr const char* INGEST_URL2 = "";

// ---- HTTP Basic Auth for the internet-facing endpoint ----
// Applied ONLY when uploading via INGEST_URL2.
// Leave both empty ("") for no authentication on INGEST_URL2.
//   e.g. the same credentials used by the nginx viewer proxy
constexpr const char* INGEST_USER = "";
constexpr const char* INGEST_PASS = "";

// ---- Upload behavior ----
// How often to attempt a connect+drain cycle when there are pending sessions.
constexpr uint32_t UPLOAD_INTERVAL_MS    = 60000;    // 60s

// How long (per SSID) to wait for association before giving up.
// With BLE coexistence, a cold WiFi.begin() can take 10-15 s.
// 25 s gives comfortable margin.  This timeout is applied independently
// to each network attempted (home first, then hotspot).
constexpr uint32_t WIFI_CONNECT_TIMEOUT_MS = 25000;  // 25s

} // namespace secrets
