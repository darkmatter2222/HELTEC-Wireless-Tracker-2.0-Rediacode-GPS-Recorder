# =============================================================================
# Heltec Tracker — .gitignore
# =============================================================================
# SECRETS: never commit credentials. Keep .env and secrets.h local only.
# Populate from .env.example / secrets.h.example when setting up a new clone.
# =============================================================================

# ----- Firmware secrets -----
src/secrets.h

# ----- API / web .env files (contain real credentials) -----
api/**/.env
web/**/.env
# catch any .env at any level
**/.env
# BUT NOT .env.example — those are safe templates
!**/.env.example

# ----- Local serial-capture / debug logs -----
drop*.txt
grab*.txt
ride*.txt
scan_dump.txt
overnight*.log
grab_watch.txt

# ----- Raw device data (not source) -----
data/

# ----- RadiaCode native track exports (imported into DB via scripts/import_tracks.py) -----
tracks/

# ----- Radiaverse sync — auth tokens and captured HAR files (contain credentials) -----
scripts/radiaverse_tokens.json
scripts/*.har

# ----- PlatformIO build artifacts -----
.pio/
.pioenvs/
.piolibdeps/
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch/
*.bin
*.elf

# ----- Python -----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.venv/
venv/
*.egg-info/

# ----- Node / npm (web viewer dev builds) -----
node_modules/
dist/
.cache/

# ----- OS / editor noise -----
.DS_Store
Thumbs.db
*.swp
*~
