# =============================================================================
# Radiological Map Ingest - Environment Configuration
# Copy this file to .env and fill in your values. The .env file is gitignored.
# =============================================================================

# ---- SSH connection to the deployment server ----
SSH_USER=your_username
SSH_HOST=192.168.86.48
SSH_KEY_PATH=~/.ssh/id_rsa

REMOTE_PATH=/home/your_username/vega-tracker-ingest

# ---- API ----
API_PORT=8030

# ---- MongoDB ----
# Pick whichever style matches your existing Mongo container deployment:
#   1) Mongo on the same host, reachable via the docker host gateway:
#        MONGO_URI=mongodb://host.docker.internal:27017
#   2) Mongo on a shared docker network by container name:
#        MONGO_URI=mongodb://mongo:27017
#   3) Mongo with auth:
#        MONGO_URI=mongodb://user:pass@host.docker.internal:27017/?authSource=admin
MONGO_URI=mongodb://host.docker.internal:27017
MONGO_DB=radiacode
MONGO_SAMPLES_COLLECTION=tracker_samples
MONGO_SESSIONS_COLLECTION=tracker_sessions

# ---- Limits (optional) ----
# MAX_BODY_BYTES=8388608
# INGEST_BATCH_SIZE=1000
